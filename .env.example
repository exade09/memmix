# Optional. The scanner runs without it, but image generation requires it.
OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=gpt-5.5
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium

# Used by /hybrid.html and /api/hybrid-image.
WAVESPEED_API_KEY=
# Optional fallback list. If set, this is used before WAVESPEED_API_KEY.
WAVESPEED_API_KEYS=
WAVESPEED_IMAGE_SIZE=1024*1024
WAVESPEED_TIMEOUT_SECONDS=120
WAVESPEED_SYNC_MODE=true
WAVESPEED_POLL_INTERVAL_SECONDS=1.0
